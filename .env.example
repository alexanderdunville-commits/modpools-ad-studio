# Copy this file to .env and fill in your key.
#   cp .env.example .env

# Required — your Claude API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — model used for generation.
# NESTLY_MODEL=claude-opus-4-8

# Optional — generation effort: low | medium | high
# Higher means better copy, slower and pricier.
# NESTLY_EFFORT=medium
